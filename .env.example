# Figma Backup Configuration
# Copy this file to .env and fill in your values

# Required: Your Figma personal access token
# Get it from: https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=

# Required: Team ID(s) to back up
# Find your team ID in the URL: https://www.figma.com/files/team/TEAM_ID/...
# For multiple teams, separate with commas: FIGMA_TEAM_IDS=111111,222222,333333
FIGMA_TEAM_IDS=

# Optional: Output directory (default: figma_backup_output)
# FIGMA_OUTPUT_DIR=figma_backup_output
